@model Mvc.Models.EmployeeViewModel
@{ ViewData["Title"] = "Delete Employee"; }

<div class="container mt-4">
    <h2 class="text-danger">Delete Employee</h2>
    <p class="lead">Are you sure you want to delete this employee?</p>

    <table class="table table-bordered w-50">
        <tr><th>Name</th><td>@Model.Name</td></tr>
        <tr><th>Email</th><td>@Model.Email</td></tr>
        <tr><th>Department</th><td>@Model.Department</td></tr>
        <tr><th>Salary</th><td>@Model.Salary.ToString("C")</td></tr>
    </table>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>