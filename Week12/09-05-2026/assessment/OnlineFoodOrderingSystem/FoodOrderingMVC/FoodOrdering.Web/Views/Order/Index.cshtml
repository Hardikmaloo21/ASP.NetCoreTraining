@model IEnumerable<FoodOrdering.Web.Models.Order>

<div class="container mt-5">

    <h2>Order History</h2>

    <table class="table table-bordered table-striped mt-4">

        <thead class="table-dark">

            <tr>

                <th>Order Id</th>

                <th>User</th>

                <th>Total Amount</th>

                <th>Status</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var order in Model)
            {
                <tr>

                    <td>@order.Id</td>

                    <td>@order.UserEmail</td>

                    <td>₹ @order.TotalAmount</td>

                    <td>@order.Status</td>

                </tr>
            }

        </tbody>

    </table>

</div>